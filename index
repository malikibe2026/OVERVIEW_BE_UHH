<script>
// ── CONSTANTS ── 
// Kolum A-K = data sedia ada. L-W = operasi (index 11-22)
const COL = {
  FE:      0,  // A – Nama FE (ubah ikut sheet sebenar)
  FASA:    1,  // B – Fasa
  KOD:     2,  // C – Kod (11/50)
  JENIS:   3,  // D – Jenis (Hartanah/Runcit)
  LK:      4,  // E – Flag LK (ya/tidak atau kod 12-60)
  // L-W = index 11-22
  L_KAWALAN:   11,
  M_BATCHING:  12,
  N_NO_BATCH:  13,
  O_PROSESAN:  14,
  P_RESP:      15,
  Q_REKOD:     16,
  R_HASIL:     17,
  S_BELANJA:   18,
  T_GAJI:      19,
  U_PEKERJA:   20,
  V_ASET:      21,
  W_STOK:      22,
};

let globalRows = [];
let feTable = null;
let charts = {};

// ── UTILS ──
function fmt(n) {
  if (n == null || isNaN(n)) return '0';
  return Number(n).toLocaleString('ms-MY');
}
function fmtDate(s) {
  if (!s) return '';
  const d = new Date(s);
  if (isNaN(d)) return s;
  return d.toLocaleDateString('ms-MY', {day:'2-digit', month:'2-digit', year:'numeric'});
}
function pct(a, b) {
  if (!b) return 0;
  return Math.round((a / b) * 100);
}
function pctBar(a, b) {
  const p = pct(a, b);
  return `${fmt(a)} <span class="mini-pct">(${p}%)</span>`;
}

// ── DEMO DATA GENERATOR ──
function generateDemo() {
  const fes = ['Ahmad Faiz','Siti Norain','Mohd Haziq','Nurul Aina','Khairul Anwar','Farah Hana','Zulaikha Bt Ali','Razif Syafiq','Ain Syakirah','Hamdan Norzaidi'];
  const fasa = ['2','2','2','2','2','3','3','3','3','3'];
  const kods = ['11','50'];
  const jenis = ['Hartanah','Runcit'];
  const resp = ['Berjaya','Tiada','Enggan','Kosong'];
  const rekod = ['Aktif','Tutup','Baharu','Pindah'];
  const rows = [];
  let batchMap = {};
  for (let i = 0; i < 500; i++) {
    const fe   = fes[i % fes.length];
    const fs   = fasa[i % fasa.length];
    const kod  = kods[Math.random() > 0.3 ? 0 : 1];
    const isLK = Math.random() > 0.7;
    const jen  = jenis[i % 2];
    const dK   = Math.random() > 0.3 ? new Date(2025, 7 + Math.floor(i/80), 1 + (i%28)).toISOString().split('T')[0] : '';
    const bno  = dK ? 'BATCH-' + (Math.floor(i / 50) + 1) : '';
    const dB   = dK ? new Date(2025, 8 + Math.floor(i/100), 5 + (i%20)).toISOString().split('T')[0] : '';
    const dP   = dK && Math.random() > 0.4 ? new Date(2025, 8 + Math.floor(i/90), 10 + (i%15)).toISOString().split('T')[0] : '';
    const r    = resp[Math.floor(Math.random() * resp.length)];
    const rek  = rekod[Math.floor(Math.random() * rekod.length)];
    // 23 columns (A-W)
    const row = ['','','','','','','','','','','','','','','','','','','','','','',''];
    row[COL.FE]        = fe;
    row[COL.FASA]      = fs;
    row[COL.KOD]       = isLK ? String(12 + (i % 49)) : kod;
    row[COL.JENIS]     = jen;
    row[COL.LK]        = isLK ? 'Ya' : 'Tidak';
    row[COL.L_KAWALAN] = dK;
    row[COL.M_BATCHING]= dB;
    row[COL.N_NO_BATCH]= bno;
    row[COL.O_PROSESAN]= dP;
    row[COL.P_RESP]    = r;
    row[COL.Q_REKOD]   = rek;
    rows.push(row);
  }
  return rows;
}

// ── PARSE CSV ──
function parseCSV(text) {
  const lines = text.trim().split('\n');
  return lines.slice(1).map(line => {
    const cols = [];
    let cur = '', inQ = false;
    for (let c of line) {
      if (c === '"') { inQ = !inQ; }
      else if (c === ',' && !inQ) { cols.push(cur.trim()); cur = ''; }
      else cur += c;
    }
    cols.push(cur.trim());
    return cols;
  }).filter(r => r.length > 5);
}

// ── LOAD FROM SHEET ──
async function loadData() {
  const url = document.getElementById('sheet-url').value.trim();
  if (!url) { alert('Sila masukkan URL Google Sheet.'); return; }
  showLoading(true);
  try {
    const res = await fetch(url);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const txt = await res.text();
    const rows = parseCSV(txt);
    if (!rows.length) throw new Error('Tiada data');
    renderAll(rows);
  } catch (e) {
    showLoading(false);
    document.getElementById('no-data').style.display = 'block';
    document.getElementById('dashboard').style.display = 'none';
    console.error(e);
  }
}

function loadDemo() {
  showLoading(true);
  setTimeout(() => {
    renderAll(generateDemo());
  }, 600);
}

function showLoading(v) {
  document.getElementById('loading-overlay').style.display = v ? 'flex' : 'none';
}

// ── RENDER ALL ──
function renderAll(rows) {
  globalRows = rows;
  document.getElementById('last-updated').textContent = new Date().toLocaleString('ms-MY');
  renderKPI(rows);
  renderFasaTables(rows);
  renderJenisTable(rows);
  renderTrendCharts(rows);
  renderStatusCharts(rows);
  renderBatchingTable(rows);
  renderFETable(rows);
  document.getElementById('dashboard').style.display = 'block';
  document.getElementById('no-data').style.display = 'none';
  showLoading(false);
}

// ── HELPER: is LK? ──
function isLK(row) {
  const k = String(row[COL.KOD] || '').trim();
  const fl = String(row[COL.LK] || '').trim().toLowerCase();
  const n = parseInt(k);
  return fl === 'ya' || (!isNaN(n) && n >= 12 && n <= 60);
}
function isKod11(row) { return String(row[COL.KOD]).trim() === '11' && !isLK(row); }
function isKod50(row) { return String(row[COL.KOD]).trim() === '50' && !isLK(row); }

// ── KPI ──
function renderKPI(rows) {
  const total   = rows.length;
  const k11     = rows.filter(isKod11).length;
  const k50     = rows.filter(isKod50).length;
  const lk      = rows.filter(isLK).length;
  const hKaw    = rows.filter(r => !isLK(r) && r[COL.L_KAWALAN]).length;
  const hKawLK  = rows.filter(r =>  isLK(r) && r[COL.L_KAWALAN]).length;
  const pTerima = rows.filter(r => !isLK(r) && r[COL.O_PROSESAN]).length;
  const pTerimaLK = rows.filter(r => isLK(r) && r[COL.O_PROSESAN]).length;

  const kpis = [
    { label:'Jumlah Agihan',            val:total,      cls:'c-blue',   icon:'📋' },
    { label:'Jumlah Kod 11',            val:k11,        cls:'c-accent', icon:'1️⃣' },
    { label:'Jumlah Kod 50',            val:k50,        cls:'c-gold',   icon:'5️⃣' },
    { label:'Jumlah LK (12–60)',        val:lk,         cls:'c-purple', icon:'📝' },
    { label:'Hantar Kawalan Borang\n(Kod 11+50)', val:hKaw,  cls:'c-green', icon:'✅', sub:`${pct(hKaw,k11+k50)}% daripada Agihan` },
    { label:'Hantar Kawalan F2\n(LK)',  val:hKawLK,     cls:'c-green',  icon:'✅', sub:`${pct(hKawLK,lk)}% daripada LK` },
    { label:'Prosesan Terima Borang',   val:pTerima,    cls:'c-red',    icon:'📥', sub:`${pct(pTerima,k11+k50)}% daripada Hantar` },
    { label:'Prosesan Terima F2 (LK)',  val:pTerimaLK,  cls:'c-red',    icon:'📥', sub:`${pct(pTerimaLK,lk)}% daripada LK` },
  ];

  document.getElementById('kpi-grid').innerHTML = kpis.map(k => `
    <div class="kpi-card ${k.cls}">
      <div class="kpi-icon">${k.icon}</div>
      <div class="kpi-label">${k.label.replace('\n','<br>')}</div>
      <div class="kpi-val">${fmt(k.val)}</div>
      ${k.sub ? `<div class="kpi-sub">${k.sub}</div>` : ''}
    </div>
  `).join('');
}

// ── PHASE TABLE ──
function phaseTableHTML(rows, fasa) {
  const sub = fasa === 'all' ? rows : rows.filter(r => String(r[COL.FASA]).trim() === fasa);
  const k11 = sub.filter(isKod11);
  const k50 = sub.filter(isKod50);
  const lkR = sub.filter(isLK);
  function stats(arr, isLkSet) {
    const agi  = arr.length;
    const hk   = arr.filter(r => r[COL.L_KAWALAN]).length;
    const pt   = arr.filter(r => r[COL.O_PROSESAN]).length;
    return [fmt(agi), pctBar(hk, agi), pctBar(pt, agi)];
  }
  const rows4 = [
    ['Kod 11', ...stats(k11)],
    ['Kod 50', ...stats(k50)],
    ['LK',     ...stats(lkR)],
    ['Jumlah', fmt(sub.length), pctBar(sub.filter(r=>r[COL.L_KAWALAN]).length, sub.length), pctBar(sub.filter(r=>r[COL.O_PROSESAN]).length, sub.length)],
  ];
  return `<thead><tr><th>Kod</th><th class="num">Agihan</th><th class="num">Hantar Kawalan</th><th class="num">Prosesan Terima</th></tr></thead>
  <tbody>${rows4.map((r,i) => `<tr ${i===3?'class="total"':''}><td>${r[0]}</td><td class="num">${r[1]}</td><td class="num">${r[2]}</td><td class="num">${r[3]}</td></tr>`).join('')}</tbody>`;
}

function renderFasaTables(rows) {
  document.getElementById('tbl-fasa2').innerHTML = phaseTableHTML(rows, '2');
  document.getElementById('tbl-fasa3').innerHTML = phaseTableHTML(rows, '3');
}

// ── JENIS TABLE ──
function renderJenisTable(rows) {
  const cats = ['Hartanah','Runcit'];
  const data = cats.map(c => {
    const sub = rows.filter(r => String(r[COL.JENIS]).trim() === c);
    const agi = sub.length;
    const hk  = sub.filter(r => r[COL.L_KAWALAN]).length;
    const pt  = sub.filter(r => r[COL.O_PROSESAN]).length;
    return [c, fmt(agi), pctBar(hk,agi), pctBar(pt,agi)];
  });
  const tot = rows.length;
  const thk = rows.filter(r=>r[COL.L_KAWALAN]).length;
  const tpt = rows.filter(r=>r[COL.O_PROSESAN]).length;
  data.push(['Jumlah', fmt(tot), pctBar(thk,tot), pctBar(tpt,tot)]);
  document.getElementById('tbl-jenis').innerHTML = `
    <thead><tr><th>Kategori</th><th class="num">Agihan</th><th class="num">Hantar Kawalan</th><th class="num">Prosesan Terima</th></tr></thead>
    <tbody>${data.map((r,i) => `<tr ${i===data.length-1?'class="total"':''}><td>${r[0]}</td><td class="num">${r[1]}</td><td class="num">${r[2]}</td><td class="num">${r[3]}</td></tr>`).join('')}</tbody>
  `;

  const counts = cats.map(c => rows.filter(r => String(r[COL.JENIS]).trim() === c).length);
  destroyChart('chart-jenis');
  charts['chart-jenis'] = new Chart(document.getElementById('chart-jenis'), {
    type: 'doughnut',
    data: {
      labels: cats,
      datasets: [{ data: counts, backgroundColor: ['#2563eb','#f59e0b'], borderWidth: 2, borderColor: '#fff' }]
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { family: "'Plus Jakarta Sans'" } } } }
    }
  });
}

// ── TREND CHARTS ──
function trendByDate(rows, colIdx) {
  const map = {};
  rows.forEach(r => {
    const d = r[colIdx]; if (!d) return;
    const k = fmtDate(d);
    map[k] = (map[k] || 0) + 1;
  });
  const keys = Object.keys(map).sort((a,b) => {
    const pa = a.split('/'), pb = b.split('/');
    return new Date(pa[2],pa[1]-1,pa[0]) - new Date(pb[2],pb[1]-1,pb[0]);
  });
  return { labels: keys, data: keys.map(k => map[k]) };
}

function destroyChart(id) {
  if (charts[id]) { charts[id].destroy(); delete charts[id]; }
}

function renderTrendCharts(rows) {
  const kw = trendByDate(rows, COL.L_KAWALAN);
  const bt = trendByDate(rows, COL.M_BATCHING);
  const pr = trendByDate(rows, COL.O_PROSESAN);

  destroyChart('chart-kawalan');
  charts['chart-kawalan'] = new Chart(document.getElementById('chart-kawalan'), {
    type: 'line',
    data: { labels: kw.labels, datasets: [{ label: 'Hantar Kawalan', data: kw.data,
      borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.08)', tension: 0.4, fill: true, pointRadius: 3 }] },
    options: lineOpts('Bil Rekod')
  });

  destroyChart('chart-batching');
  charts['chart-batching'] = new Chart(document.getElementById('chart-batching'), {
    type: 'bar',
    data: { labels: bt.labels, datasets: [{ label: 'Hantar Batching', data: bt.data,
      backgroundColor: 'rgba(245,158,11,0.75)', borderRadius: 5 }] },
    options: lineOpts('Bil Rekod')
  });

  destroyChart('chart-prosesan');
  charts['chart-prosesan'] = new Chart(document.getElementById('chart-prosesan'), {
    type: 'line',
    data: { labels: pr.labels, datasets: [{ label: 'Prosesan Terima', data: pr.data,
      borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.08)', tension: 0.4, fill: true, pointRadius: 3 }] },
    options: lineOpts('Bil Rekod')
  });
}

function lineOpts(yLabel) {
  return {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      x: { ticks: { font: { size: 10, family: "'Plus Jakarta Sans'" }, maxRotation: 45 }, grid: { display: false } },
      y: { ticks: { font: { size: 10 } }, beginAtZero: true, title: { display: true, text: yLabel, font: { size: 10 } } }
    }
  };
}

// ── STATUS CHARTS ──
function countByCol(rows, col) {
  const map = {};
  rows.forEach(r => {
    const v = String(r[col] || '').trim() || 'Tiada Data';
    map[v] = (map[v] || 0) + 1;
  });
  return map;
}

function renderStatusCharts(rows) {
  const respMap = countByCol(rows, COL.P_RESP);
  const rekodMap = countByCol(rows, COL.Q_REKOD);

  const COLORS = ['#2563eb','#f59e0b','#10b981','#ef4444','#8b5cf6','#06b6d4','#f97316'];

  // Status Response Pie
  destroyChart('chart-response');
  charts['chart-response'] = new Chart(document.getElementById('chart-response'), {
    type: 'pie',
    data: {
      labels: Object.keys(respMap),
      datasets: [{ data: Object.values(respMap), backgroundColor: COLORS, borderWidth: 2, borderColor: '#fff' }]
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { family: "'Plus Jakarta Sans'", size: 11 } } } }
    }
  });

  // Status Rekod Doughnut
  destroyChart('chart-rekod');
  charts['chart-rekod'] = new Chart(document.getElementById('chart-rekod'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(rekodMap),
      datasets: [{ data: Object.values(rekodMap), backgroundColor: COLORS, borderWidth: 2, borderColor: '#fff' }]
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { family: "'Plus Jakarta Sans'", size: 11 } } } }
    }
  });

  // Response table
  const tot = rows.length;
  document.getElementById('tbl-response').innerHTML = `
    <thead><tr><th>Status</th><th class="num">Bil</th><th class="num">%</th></tr></thead>
    <tbody>${Object.entries(respMap).sort((a,b)=>b[1]-a[1]).map(([k,v]) =>
      `<tr><td>${k}</td><td class="num">${fmt(v)}</td><td class="num">${pct(v,tot)}%</td></tr>`).join('')}
    </tbody>`;

  document.getElementById('tbl-rekod').innerHTML = `
    <thead><tr><th>Status</th><th class="num">Bil</th><th class="num">%</th></tr></thead>
    <tbody>${Object.entries(rekodMap).sort((a,b)=>b[1]-a[1]).map(([k,v]) =>
      `<tr><td>${k}</td><td class="num">${fmt(v)}</td><td class="num">${pct(v,tot)}%</td></tr>`).join('')}
    </tbody>`;
}

// ── BATCHING TABLE ──
function renderBatchingTable(rows) {
  const map = {};
  rows.forEach(r => {
    const bno = String(r[COL.N_NO_BATCH] || '').trim(); if (!bno) return;
    if (!map[bno]) map[bno] = { bil:0, tHantar: r[COL.M_BATCHING] || '', bilProsesan:0 };
    map[bno].bil++;
    if (r[COL.O_PROSESAN]) map[bno].bilProsesan++;
    if (!map[bno].tHantar && r[COL.M_BATCHING]) map[bno].tHantar = r[COL.M_BATCHING];
  });

  const entries = Object.entries(map).sort((a,b) => a[0].localeCompare(b[0]));
  document.getElementById('tbl-batching').innerHTML = `
    <thead><tr><th>No. Batching</th><th class="num">Bil Borang</th><th class="num">Tarikh Hantar</th><th class="num">Bil Prosesan Terima</th></tr></thead>
    <tbody>${entries.length ? entries.map(([bno, d]) =>
      `<tr><td><span class="badge badge-blue">${bno}</span></td>
        <td class="num">${fmt(d.bil)}</td>
        <td class="num">${fmtDate(d.tHantar)}</td>
        <td class="num">${pctBar(d.bilProsesan, d.bil)}</td></tr>`).join('') :
      '<tr><td colspan="4" style="text-align:center;color:var(--muted)">Tiada data batching</td></tr>'}
    </tbody>`;
}

// ── FE TABLE ──
function renderFETable(rows) {
  // aggregate by FE
  const map = {};
  rows.forEach(r => {
    const fe = String(r[COL.FE] || '').trim() || 'Tidak Dikenali';
    if (!map[fe]) map[fe] = { agi:0, k11:0, k50:0, lk:0, hB:0, hF2:0, tB:0, tF2:0 };
    const m = map[fe];
    m.agi++;
    if (isKod11(r)) m.k11++;
    else if (isKod50(r)) m.k50++;
    else if (isLK(r)) m.lk++;
    if (!isLK(r) && r[COL.L_KAWALAN]) m.hB++;
    if ( isLK(r) && r[COL.L_KAWALAN]) m.hF2++;
    if (!isLK(r) && r[COL.O_PROSESAN]) m.tB++;
    if ( isLK(r) && r[COL.O_PROSESAN]) m.tF2++;
  });

  const tbody = document.getElementById('fe-tbody');
  tbody.innerHTML = Object.entries(map).map(([fe, d]) =>
    `<tr><td>${fe}</td><td>${fmt(d.agi)}</td><td>${fmt(d.k11)}</td><td>${fmt(d.k50)}</td><td>${fmt(d.lk)}</td>
     <td>${fmt(d.hB)}</td><td>${fmt(d.hF2)}</td><td>${fmt(d.tB)}</td><td>${fmt(d.tF2)}</td></tr>`
  ).join('');

  if (feTable) { feTable.destroy(); feTable = null; }
  feTable = $('#fe-table').DataTable({
    dom: 'Bfrtip',
    buttons: [{ extend: 'csv', text: '⬇ Export CSV', filename: 'prestasi_fe' }],
    pageLength: 10,
    language: {
      search: 'Cari:', paginate: { previous:'‹', next:'›' },
      info: 'Paparan _START_–_END_ daripada _TOTAL_ rekod',
      lengthMenu: 'Papar _MENU_ rekod', zeroRecords: 'Tiada rekod dijumpai',
      infoEmpty: 'Tiada rekod', infoFiltered: '(ditapis daripada _MAX_ jumlah rekod)'
    },
    columnDefs: [{ targets: '_all', className: 'dt-right' }, { targets: 0, className: '' }],
    order: [[1, 'desc']],
    scrollX: true
  });
}

