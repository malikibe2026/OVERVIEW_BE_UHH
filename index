// ── PASSWORD GATE ──
(function(){
  // Hash cyrb53 bagi kata laluan — kata laluan sebenar tidak disimpan dalam fail.
  const GATE_HASH = "5777457859756829";
  const cyrb53 = (str, seed = 0) => {
    let h1 = 0xdeadbeef ^ seed, h2 = 0x41c6ce57 ^ seed;
    for (let i = 0, ch; i < str.length; i++) {
      ch = str.charCodeAt(i);
      h1 = Math.imul(h1 ^ ch, 2654435761);
      h2 = Math.imul(h2 ^ ch, 1597334677);
    }
    h1 = Math.imul(h1 ^ (h1 >>> 16), 2246822507);
    h1 ^= Math.imul(h2 ^ (h2 >>> 13), 3266489909);
    h2 = Math.imul(h2 ^ (h2 >>> 16), 2246822507);
    h2 ^= Math.imul(h1 ^ (h1 >>> 13), 3266489909);
    return (4294967296 * (2097151 & h2) + (h1 >>> 0)).toString();
  };

  const gate   = document.getElementById('gate');
  const wrap   = document.getElementById('gate-wrap');
  const input  = document.getElementById('gate-pass');
  const submit = document.getElementById('gate-submit');
  const err    = document.getElementById('gate-err');
  const eye    = document.getElementById('gate-eye');
  const KEY    = 'be2026_borang_unlocked';

  function unlock(skipStore){
    try { if (!skipStore) sessionStorage.setItem(KEY, '1'); } catch(e) {}
    gate.classList.add('gate-hide');
    setTimeout(() => { gate.style.display = 'none'; }, 480);
  }

  function fail(){
    err.textContent = 'Kata laluan salah. Sila cuba lagi.';
    err.classList.add('show');
    wrap.classList.add('shake');
    input.value = '';
    setTimeout(() => wrap.classList.remove('shake'), 420);
    input.focus();
  }

  function check(){
    const v = input.value;
    if (!v) { input.focus(); return; }
    if (cyrb53(v) === GATE_HASH) unlock(false);
    else fail();
  }

  // Sesi sedia ada — jangan minta kata laluan semula dalam tab yang sama
  let already = false;
  try { already = sessionStorage.getItem(KEY) === '1'; } catch(e) {}
  if (already) { unlock(true); }
  else { setTimeout(() => input.focus(), 350); }

  submit.addEventListener('click', check);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') check(); });
  input.addEventListener('input', () => err.classList.remove('show'));
  input.addEventListener('focus', () => wrap.classList.add('focus'));
  input.addEventListener('blur',  () => wrap.classList.remove('focus'));
  eye.addEventListener('click', () => {
    const show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    eye.textContent = show ? '🙈' : '👁';
    input.focus();
  });
})();
</script>
