<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Banci Ekonomi – DOSM SELANGOR:UHH</title>

<!-- Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<!-- DataTables -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

<style>
:root {
  --navy:     #0a1628;
  --navy2:    #0f2044;
  --blue:     #1a4fad;
  --blue2:    #2563eb;
  --accent:   #38bdf8;
  --gold:     #f59e0b;
  --green:    #10b981;
  --red:      #ef4444;
  --purple:   #8b5cf6;
  --white:    #ffffff;
  --bg:       #f0f4fb;
  --card:     #ffffff;
  --border:   #dde4f0;
  --text:     #1e2d4a;
  --muted:    #64748b;
  --shadow:   0 2px 16px rgba(10,22,40,0.09);
  --shadow2:  0 8px 32px rgba(10,22,40,0.13);
  --radius:   14px;
  --font:     'Plus Jakarta Sans', sans-serif;
  --mono:     'DM Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* ── HEADER ── */
.header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 50%, #112255 100%);
  color: var(--white);
  padding: 0;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.header-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 32px;
  gap: 20px;
  flex-wrap: wrap;
}
.header-logo {
  display: flex;
  align-items: center;
  gap: 16px;
}
.header-badge {
  width: 52px;
  height: 52px;
  background: linear-gradient(135deg, var(--blue2), var(--accent));
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}
.header-title h1 {
  font-size: 1.35rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  line-height: 1.2;
}
.header-title p {
  font-size: 0.82rem;
  opacity: 0.7;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-top: 3px;
}
.header-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
}
.header-meta .survey-tag {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.04em;
}
.header-meta .updated {
  font-size: 0.75rem;
  opacity: 0.6;
}
.header-meta .updated span {
  font-family: var(--mono);
  color: var(--accent);
  opacity: 1;
}

/* ── CONTROLS BAR ── */
.ctrl-bar {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 10px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}
.ctrl-bar label {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--muted);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.ctrl-bar input[type="text"] {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 7px 14px;
  font-size: 0.83rem;
  font-family: var(--mono);
  color: var(--text);
  width: 440px;
  max-width: 100%;
  transition: border .2s;
}
.ctrl-bar input:focus { outline: none; border-color: var(--blue2); }
.btn {
  background: var(--blue2);
  color: var(--white);
  border: none;
  border-radius: 8px;
  padding: 8px 20px;
  font-size: 0.83rem;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: background .2s, transform .1s;
}
.btn:hover { background: var(--blue); }
.btn:active { transform: scale(.97); }
.btn-ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
}
.btn-ghost:hover { background: var(--bg); color: var(--text); }

/* ── MAIN LAYOUT ── */
.main { padding: 28px 32px; max-width: 1600px; margin: 0 auto; }

/* ── SECTION TITLE ── */
.sec-title {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  margin-top: 36px;
}
.sec-title:first-child { margin-top: 0; }
.sec-title h2 {
  font-size: 1.0rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--navy2);
}
.sec-title .pill {
  background: var(--blue2);
  color: #fff;
  border-radius: 20px;
  padding: 2px 10px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
}
.sec-divider {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
  margin-left: 8px;
}

/* ── KPI CARDS ── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px;
}
.kpi-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 22px 20px 18px;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}
.kpi-card:hover { box-shadow: var(--shadow2); transform: translateY(-2px); }
.kpi-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: var(--radius) var(--radius) 0 0;
}
.kpi-card.c-blue::after   { background: var(--blue2); }
.kpi-card.c-accent::after { background: var(--accent); }
.kpi-card.c-green::after  { background: var(--green); }
.kpi-card.c-gold::after   { background: var(--gold); }
.kpi-card.c-red::after    { background: var(--red); }
.kpi-card.c-purple::after { background: var(--purple); }
.kpi-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 10px;
  line-height: 1.4;
}
.kpi-val {
  font-family: var(--mono);
  font-size: 2.1rem;
  font-weight: 500;
  color: var(--navy);
  line-height: 1;
}
.kpi-sub {
  font-size: 0.72rem;
  color: var(--muted);
  margin-top: 8px;
}
.kpi-icon {
  position: absolute;
  right: 18px;
  top: 18px;
  font-size: 1.5rem;
  opacity: 0.13;
}

/* ── TABLES ── */
.card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  overflow: hidden;
  margin-bottom: 20px;
}
.card-head {
  padding: 16px 22px 14px;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--navy2);
  letter-spacing: 0.02em;
  display: flex;
  align-items: center;
  gap: 8px;
}
.card-body { padding: 18px 22px; }
table.dash-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.83rem;
}
table.dash-table th {
  background: var(--bg);
  color: var(--navy2);
  font-weight: 700;
  padding: 10px 14px;
  text-align: left;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border-bottom: 2px solid var(--border);
}
table.dash-table th.num,
table.dash-table td.num { text-align: right; }
table.dash-table td {
  padding: 10px 14px;
  border-bottom: 1px solid #f0f3fa;
  color: var(--text);
}
table.dash-table tr:last-child td { border-bottom: none; }
table.dash-table tr.total td {
  font-weight: 700;
  background: #f5f8ff;
  color: var(--navy2);
  border-top: 2px solid var(--border);
}
table.dash-table td.num { font-family: var(--mono); }
.pct-bar {
  display: inline-block;
  height: 5px;
  background: var(--blue2);
  border-radius: 3px;
  margin-left: 6px;
  vertical-align: middle;
  opacity: 0.4;
  min-width: 2px;
}

/* ── TWO-COL PHASE LAYOUT ── */
.phase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 900px) { .phase-grid { grid-template-columns: 1fr; } }

/* ── CHARTS ROW ── */
.chart-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 20px;
  margin-bottom: 20px;
}
.chart-card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  padding: 20px;
}
.chart-card h3 {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--navy2);
  margin-bottom: 16px;
}
.chart-wrap { position: relative; height: 220px; }

/* ── STATUS TABLES ── */
.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 900px) { .status-grid { grid-template-columns: 1fr; } }

/* ── DATATABLE ── */
#fe-table_wrapper { padding: 0; }
#fe-table_wrapper .dataTables_filter input {
  border: 1px solid var(--border);
  border-radius: 7px;
  padding: 5px 12px;
  font-family: var(--font);
  font-size: 0.82rem;
}
#fe-table_wrapper .dt-buttons button {
  background: var(--navy2);
  color: var(--white);
  border: none;
  border-radius: 7px;
  padding: 6px 14px;
  font-size: 0.78rem;
  font-family: var(--font);
  font-weight: 600;
  cursor: pointer;
  margin-right: 4px;
}
table#fe-table {
  font-size: 0.78rem;
}
table#fe-table th {
  background: var(--navy2);
  color: #fff;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 10px 10px;
  white-space: nowrap;
}
table#fe-table td {
  padding: 8px 10px;
  border-bottom: 1px solid #f0f3fa;
  white-space: nowrap;
}
table#fe-table td:not(:first-child) { font-family: var(--mono); text-align: right; }
table#fe-table tr:hover td { background: #f5f8ff; }
.dataTables_paginate .paginate_button.current {
  background: var(--blue2) !important;
  color: #fff !important;
  border-radius: 5px;
  border: none !important;
}

/* ── SPINNER ── */
#loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,22,40,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(4px);
}
.spinner {
  width: 48px; height: 48px;
  border: 4px solid rgba(255,255,255,0.15);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
#loading-overlay p { color: var(--white); margin-top: 16px; font-size: 0.9rem; opacity: 0.8; }

/* ── ERROR ── */
.err-msg {
  background: #fff5f5;
  border: 1px solid #fed7d7;
  color: #9b2c2c;
  border-radius: var(--radius);
  padding: 18px 22px;
  font-size: 0.85rem;
  margin-bottom: 20px;
}

/* ── RESPONSIVE ── */
@media (max-width: 700px) {
  .main { padding: 16px; }
  .header-inner { padding: 16px; }
  .ctrl-bar { padding: 10px 16px; }
  .ctrl-bar input[type="text"] { width: 100%; }
  .kpi-grid { grid-template-columns: 1fr 1fr; }
  .chart-grid { grid-template-columns: 1fr; }
}

/* ── BADGES ── */
.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.04em;
}
.badge-blue   { background: #dbeafe; color: #1d4ed8; }
.badge-green  { background: #d1fae5; color: #065f46; }
.badge-gold   { background: #fef3c7; color: #92400e; }
.badge-red    { background: #fee2e2; color: #991b1b; }

/* progress ring placeholder */
.mini-pct {
  font-family: var(--mono);
  font-size: 0.68rem;
  color: var(--muted);
  margin-left: 4px;
}

/* ── PASSWORD GATE ── */
#gate {
  position: fixed;
  inset: 0;
  z-index: 100000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 50%, #112255 100%);
  overflow: hidden;
}
#gate::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
#gate::after {
  content: '';
  position: absolute;
  width: 520px;
  height: 520px;
  border-radius: 50%;
  top: -180px;
  right: -160px;
  background: radial-gradient(circle, rgba(56,189,248,0.18), transparent 70%);
  filter: blur(8px);
}
#gate.gate-hide {
  opacity: 0;
  visibility: hidden;
  transition: opacity .45s ease, visibility .45s ease;
}
.gate-card {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 410px;
  background: rgba(15, 32, 68, 0.55);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 20px;
  padding: 38px 34px 30px;
  box-shadow: 0 24px 70px rgba(0,0,0,0.45);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  text-align: center;
  animation: gateIn .5s cubic-bezier(.2,.8,.2,1);
}
@keyframes gateIn {
  from { opacity: 0; transform: translateY(18px) scale(.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.gate-badge {
  width: 64px;
  height: 64px;
  margin: 0 auto 18px;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--blue2), var(--accent));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  box-shadow: 0 10px 30px rgba(37,99,235,0.4);
}
.gate-card h1 {
  color: var(--white);
  font-size: 1.18rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  line-height: 1.3;
}
.gate-sub {
  color: rgba(255,255,255,0.55);
  font-size: 0.76rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 8px;
  margin-bottom: 26px;
}
.gate-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(10,22,40,0.55);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 11px;
  padding: 0 6px 0 14px;
  transition: border-color .2s, box-shadow .2s;
}
.gate-input-wrap.focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(56,189,248,0.15);
}
.gate-input-wrap.shake { animation: shake .4s; }
@keyframes shake {
  0%,100% { transform: translateX(0); }
  20%,60% { transform: translateX(-7px); }
  40%,80% { transform: translateX(7px); }
}
.gate-lock { font-size: 1rem; opacity: 0.7; flex-shrink: 0; }
#gate-pass {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--white);
  font-family: var(--mono);
  font-size: 0.95rem;
  letter-spacing: 0.12em;
  padding: 13px 10px;
}
#gate-pass::placeholder { color: rgba(255,255,255,0.32); letter-spacing: 0.04em; font-family: var(--font); }
.gate-eye {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 1rem;
  opacity: 0.55;
  padding: 8px;
  transition: opacity .15s;
}
.gate-eye:hover { opacity: 1; }
.gate-btn {
  width: 100%;
  margin-top: 16px;
  background: linear-gradient(135deg, var(--blue2), var(--blue));
  color: var(--white);
  border: none;
  border-radius: 11px;
  padding: 14px;
  font-family: var(--font);
  font-size: 0.92rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: filter .2s, transform .1s;
}
.gate-btn:hover { filter: brightness(1.1); }
.gate-btn:active { transform: scale(.98); }
.gate-err {
  color: #fca5a5;
  font-size: 0.78rem;
  font-weight: 600;
  margin-top: 14px;
  min-height: 18px;
  opacity: 0;
  transition: opacity .2s;
}
.gate-err.show { opacity: 1; }
.gate-foot {
  margin-top: 24px;
  padding-top: 18px;
  border-top: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.4);
  font-size: 0.7rem;
  letter-spacing: 0.05em;
}
.gate-foot span { font-family: var(--mono); color: var(--accent); opacity: 0.8; }
</style>
</head>
<body>

<!-- PASSWORD GATE -->
<div id="gate">
  <div class="gate-card">
    <div class="gate-badge">🔐</div>
    <h1>LAPORAN PENGHANTARAN BORANG</h1>
    <div class="gate-sub">BPAH / UHH &nbsp;·&nbsp; DOSM Selangor</div>
    <div class="gate-input-wrap" id="gate-wrap">
      <span class="gate-lock">🔒</span>
      <input type="password" id="gate-pass" placeholder="Masukkan kata laluan" autocomplete="off" autocapitalize="off" spellcheck="false">
      <button type="button" class="gate-eye" id="gate-eye" title="Papar/sembunyi">👁</button>
    </div>
    <button type="button" class="gate-btn" id="gate-submit">Buka Dashboard →</button>
    <div class="gate-err" id="gate-err"></div>
    <div class="gate-foot">Akses Terhad &nbsp;·&nbsp; Banci Ekonomi <span>BE2026</span></div>
  </div>
</div>

<!-- LOADING OVERLAY -->
<div id="loading-overlay">
  <div class="spinner"></div>
  <p>Memuatkan data...</p>
</div>

<!-- HEADER -->
<div class="header">
  <div class="header-inner">
    <div class="header-logo">
      <div class="header-badge">📋</div>
      <div class="header-title">
        <h1>LAPORAN PENGHANTARAN BORANG</h1>
        <p>Fasa 2 &amp; Fasa 3 &nbsp;·&nbsp; KodSurvei 308 &nbsp;·&nbsp; BPAH / UHH</p>
      </div>
    </div>
    <div class="header-meta">
      <div class="survey-tag">DOSM SELANGOR</div>
      <div class="updated">Kemaskini: <span id="last-updated">—</span></div>
    </div>
  </div>
</div>

<!-- CONTROLS BAR -->
<div class="ctrl-bar">
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
